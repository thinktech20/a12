# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# GE Vernova LiteLLM gateway — values from pw_sdg_ai_ser_repo/databricks.yaml (dev target)
LITELLM_BASE_URL=https://dev-gateway.apps.gevernova.net
LITELLM_API_KEY=

# Models exposed by the gateway (same names prod uses)
EMBEDDING_MODEL=azure-text-embedding-3-large-1
CHAT_MODEL=gemini-3-flash

# Corp networks often need verify=False on the gateway. Set to true if your CA bundle is set up.
LLM_VERIFY_SSL=false
